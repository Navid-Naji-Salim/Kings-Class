{
  "name": "@kings-class/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:start": "prisma dev --name kings-class --detach",
    "db:list": "prisma dev ls",
